      m_Items: []
  - m_Id: 2889076209344512
    m_Localized: Bro Office Worker
    m_Metadata:
      m_Items: []
  - m_Id: 2889076310007808
    m_Localized: This hallway is a great place to get your cardio in.  I'm really
