%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Speech_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: 991c04154cea34203a64a5fe4f5e097e, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 2889047881015296
    m_Localized: Theo
    m_Metadata:
      m_Items: []
  - m_Id: 2889048443052032
    m_Localized: "H\xE9 Francis ! Tu veux sauvegarder ta progression jusqu'ici ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889048552103936
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889048648572928
    m_Localized: "Oui, s'il te pla\xEEt !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889048753430528
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889048849899520
    m_Localized: Non, merci.
    m_Metadata:
      m_Items: []
  - m_Id: 2889048950562816
    m_Localized: "D\xE9faut"
    m_Metadata:
      m_Items: []
  - m_Id: 2889049051226112
    m_Localized: "N\u0153ud racine ignor\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 2889049147695104
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889049244164096
    m_Localized: "C'est quoi \xE7a ? Tu dis m'avoir vue \xE0 la PortaBank (MC) ?
      Je ne vois pas de quoi tu parles, je travaille ici."
    m_Metadata:
      m_Items: []
  - m_Id: 2889049344827392
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889049441296384
    m_Localized: "\xC0 part toi et Cheval, je suis litt\xE9ralement la seule personne
      qui fait du travail ici"
    m_Metadata:
      m_Items: []
  - m_Id: 2889049541959680
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889049638428672
    m_Localized: "Tu veux la cl\xE9 de la salle \xE0 balles ? Tr\xE8s bien, on danse."
    m_Metadata:
      m_Items: []
  - m_Id: 2889049739091968
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889049835560960
    m_Localized: "Bonjour Tilly, belle coiffure, je veux dire, belle tenue, je veux
      dire . . . bref, tu veux tra\xEEner ce week-end ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889049936224256
    m_Localized: Steve5000
    m_Metadata:
      m_Items: []
  - m_Id: 2889050032693248
    m_Localized: "N\u0153ud racine ignor\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 2889050129162240
    m_Localized: Steve5000
    m_Metadata:
      m_Items: []
  - m_Id: 2889050229825536
    m_Localized: Oh, salut Francis . . . euh, Frankie.
    m_Metadata:
      m_Items: []
  - m_Id: 2889050326294528
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889050426957824
    m_Localized: "Euh . . . c'\xE9tait quoi \xE7a ? T'es quoi, toi ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889050523426816
    m_Localized: Steve5000
    m_Metadata:
      m_Items: []
  - m_Id: 2889050624090112
    m_Localized: "T'as encore oubli\xE9 ta carte-cl\xE9 ? Tu peux emprunter la mienne,
      je suis justement en train de partir."
    m_Metadata:
      m_Items: []
  - m_Id: 2889050720559104
    m_Localized: Steve5000
    m_Metadata:
      m_Items: []
  - m_Id: 2889050821222400
    m_Localized: "H\xE9, \xE9coute -- avant que t'entres l\xE0-dedans, tu devrais
      savoir -- les stagiaires se comportent vraiment bizarrement."
    m_Metadata:
      m_Items: []
  - m_Id: 2889050917691392
    m_Localized: Steve5000
    m_Metadata:
      m_Items: []
  - m_Id: 2889051018354688
    m_Localized: "R\xE9visons tes comp\xE9tences de combat, je veux pas que tu te
      retrouves dans l'embarras."
    m_Metadata:
      m_Items: []
  - m_Id: 2889051119017984
    m_Localized: Steve5000
    m_Metadata:
      m_Items: []
  - m_Id: 2889051215486976
    m_Localized: "Je vois pas de quoi tu parles, mon pote ! Pourquoi tu rentres pas
      l\xE0-dedans et tu leur montres qui c'est le patron ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889051316150272
    m_Localized: Hipster
    m_Metadata:
      m_Items: []
  - m_Id: 2889051412619264
    m_Localized: Ignorer
    m_Metadata:
      m_Items: []
  - m_Id: 2889051513282560
    m_Localized: Hipster
    m_Metadata:
      m_Items: []
  - m_Id: 2889051609751552
    m_Localized: Cet ascenseur est en panne.
    m_Metadata:
      m_Items: []
  - m_Id: 2889051706220544
    m_Localized: Hipster
    m_Metadata:
      m_Items: []
  - m_Id: 2889051806883840
    m_Localized: "Je crois que le disjoncteur \xE9lectrique a saut\xE9 et doit \xEAtre
      r\xE9initialis\xE9, mais il est au sous-sol et les employ\xE9s ici sont un
      peu devenus fous."
    m_Metadata:
      m_Items: []
  - m_Id: 2889051903352832
    m_Localized: Hipster
    m_Metadata:
      m_Items: []
  - m_Id: 2889052004016128
    m_Localized: "Yeehaw, t'as r\xE9ussi ! Esp\xE8ce de fou, t'as vraiment foutrement
      r\xE9ussi !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889052104679424
    m_Localized: Hipster
    m_Metadata:
      m_Items: []
  - m_Id: 2889052205342720
    m_Localized: "Tu pourrais peut-\xEAtre aller v\xE9rifier \xE7a ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889052306006016
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889052419252224
    m_Localized: Racine
    m_Metadata:
      m_Items: []
  - m_Id: 2889052524109824
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889052628967424
    m_Localized: "J'ai eu ces super remises sur des hangars portables remis \xE0
      neuf ! Tu y crois ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889052729630720
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889052830294016
    m_Localized: Oh, tu veux que je sauvegarde ta progression jusqu'ici ?
    m_Metadata:
      m_Items: []
  - m_Id: 2889052930957312
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889053031620608
    m_Localized: "Bien s\xFBr !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889053136478208
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889053237141504
    m_Localized: Non, pas aujourd'hui
    m_Metadata:
      m_Items: []
  - m_Id: 2889053337804800
    m_Localized: "Moine Ensorcel\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 2889053438468096
    m_Localized: "Je suis tellement a\xE9rodynamique !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889053539131392
    m_Localized: L'il Slugger
    m_Metadata:
      m_Items: []
  - m_Id: 2889053652377600
    m_Localized: Racine
    m_Metadata:
      m_Items: []
  - m_Id: 2889053761429504
    m_Localized: L'il Slugger
    m_Metadata:
      m_Items: []
  - m_Id: 2889053870481408
    m_Localized: Quoi ?
    m_Metadata:
      m_Items: []
  - m_Id: 2889053983727616
    m_Localized: L'il Slugger
    m_Metadata:
      m_Items: []
  - m_Id: 2889054088585216
    m_Localized: Et alors ?
    m_Metadata:
      m_Items: []
  - m_Id: 2889054206025728
    m_Localized: L'il Slugger
    m_Metadata:
      m_Items: []
  - m_Id: 2889054319271936
    m_Localized: Va te faire voir.
    m_Metadata:
      m_Items: []
  - m_Id: 2889054432518144
    m_Localized: L'il Slugger
    m_Metadata:
      m_Items: []
  - m_Id: 2889054545764352
    m_Localized: "Esp\xE8ce de nerd !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889054659010560
    m_Localized: "Moine Envo\xFBt\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 2889054776451072
    m_Localized: Moins de cheveux, plus de neurones.
    m_Metadata:
      m_Items: []
  - m_Id: 2889054889697280
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889055002943488
    m_Localized: Attends ! Ne me fais pas de mal, je ne suis pas un campagnol ordinaire
      !
    m_Metadata:
      m_Items: []
  - m_Id: 2889055116189696
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889055229435904
    m_Localized: "J'ai beau \xEAtre un petit rongeur, mon esprit est vaste et mes
      exp\xE9riences multitudinaires."
    m_Metadata:
      m_Items: []
  - m_Id: 2889055338487808
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889055451734016
    m_Localized: "Maintenant, passons aux choses s\xE9rieuses. Toi -- oui TOI, derri\xE8re
      le clavier -- tu devrais savoir que tes ennemis n'attendront pas leur tour."
    m_Metadata:
      m_Items: []
  - m_Id: 2889055564980224
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889055678226432
    m_Localized: "Alors r\xE9vise avant tes combats -- tu peux voir ce que tu peux
      faire en appuyant sur Tab et en s\xE9lectionnant Capacit\xE9s."
    m_Metadata:
      m_Items: []
  - m_Id: 2889055791472640
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889055900524544
    m_Localized: "En combat, s\xE9lectionne la capacit\xE9 que tu veux avec tes touches
      \xAB W-A-S-D \xBB puis confirme avec \xAB E \xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 2889056017965056
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889056131211264
    m_Localized: "J'esp\xE8re que c'est clair -- je ne parle pas vraiment ta langue.
      Je r\xE9cite juste ce que j'ai lu dans le Manuel Officiel du Jeu Frankie (MC)."
    m_Metadata:
      m_Items: []
  - m_Id: 2889056248651776
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889056357703680
    m_Localized: "C'est la derni\xE8re phrase que j'ai m\xE9moris\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 2889056466755584
    m_Localized: Campagnol Serviable
    m_Metadata:
      m_Items: []
  - m_Id: 2889056575807488
    m_Localized: Couic.
    m_Metadata:
      m_Items: []
  - m_Id: 2889056684859392
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889056798105600
    m_Localized: Racine
    m_Metadata:
      m_Items: []
  - m_Id: 2889056911351808
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889057020403712
    m_Localized: "J'ai eu ce petit sapin d\xE9sodorisant pour aider \xE0 rafra\xEEchir
      l'air ! Alors, tu te sens FRAIS ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889057133649920
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889057242701824
    m_Localized: Oh, tu veux que je sauvegarde ta progression jusqu'ici ?
    m_Metadata:
      m_Items: []
  - m_Id: 2889057355948032
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889057460805632
    m_Localized: "Bien s\xFBr !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889057569857536
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889057674715136
    m_Localized: Non, pas aujourd'hui
    m_Metadata:
      m_Items: []
  - m_Id: 2889057775378432
    m_Localized: "Travailleur Qualifi\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 2889057880236032
    m_Localized: '*prout* Pas trop s''approcher. *pfft*'
    m_Metadata:
      m_Items: []
  - m_Id: 2889057980899328
    m_Localized: "Travailleur Qualifi\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 2889058085756928
    m_Localized: "Je viens de p\xE9ter . . . *blaaaat*"
    m_Metadata:
      m_Items: []
  - m_Id: 2889058190614528
    m_Localized: "Travailleur Qualifi\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 2889058291277824
    m_Localized: "*pbbbt* Peut-\xEAtre que le chili d'hier soir \xE9tait une mauvaise
      id\xE9e. *poot*"
    m_Metadata:
      m_Items: []
  - m_Id: 2889058391941120
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889058496798720
    m_Localized: Racine
    m_Metadata:
      m_Items: []
  - m_Id: 2889058597462016
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889058702319616
    m_Localized: "BONJOUR ! Bienvenue \xE0 la PortaBank (MC) ! Votre solution bancaire
      portable num\xE9ro un !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889058802982912
    m_Localized: Maya
    m_Metadata:
      m_Items: []
  - m_Id: 2889058903646208
    m_Localized: Oh, tu veux que je sauvegarde ta progression jusqu'ici ?
    m_Metadata:
      m_Items: []
  - m_Id: 2889059004309504
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889059109167104
    m_Localized: "Bien s\xFBr !"
    m_Metadata:
      m_Items: []
  - m_Id: 2889059209830400
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889059314688000
    m_Localized: Non, pas aujourd'hui
    m_Metadata:
      m_Items: []
  - m_Id: 2889059419545600
    m_Localized: Jolie Fille
    m_Metadata:
      m_Items: []
  - m_Id: 2889059520208896
    m_Localized: "Wow ! T'as vraiment travers\xE9 toute la for\xEAt ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889059620872192
    m_Localized: Jolie Fille
    m_Metadata:
      m_Items: []
  - m_Id: 2889059717341184
    m_Localized: "Un \xE9cureuil m'a regard\xE9e bizarrement. Maintenant j'ai trop
      peur m\xEAme de mettre les pieds l\xE0-dedans."
    m_Metadata:
      m_Items: []
  - m_Id: 2889059818004480
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889059918667776
    m_Localized: "n\u0153ud racine"
    m_Metadata:
      m_Items: []
  - m_Id: 2889060019331072
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889060115800064
    m_Localized: '*toux* *hrrk* Eh bien . . .'
    m_Metadata:
      m_Items: []
  - m_Id: 2889060216463360
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889060317126656
    m_Localized: "Il n'y a plus rien \xE0 faire ici . . . Au revoir Phil."
    m_Metadata:
      m_Items: []
  - m_Id: 2889060417789952
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889060518453248
    m_Localized: "On dirait que c'est la fin pour moi. J'esp\xE9rais pouvoir t'accompagner
      plus loin."
    m_Metadata:
      m_Items: []
  - m_Id: 2889060614922240
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889060715585536
    m_Localized: On dirait juste de vieilles ordures ordinaires.
    m_Metadata:
      m_Items: []
  - m_Id: 2889060816248832
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889060912717824
    m_Localized: "Je suppose que je ne suis qu'une tasse de ramen apr\xE8s tout."
    m_Metadata:
      m_Items: []
  - m_Id: 2889061013381120
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889061114044416
    m_Localized: "Oh, j'avais presque oubli\xE9 -- mes derni\xE8res paroles :"
    m_Metadata:
      m_Items: []
  - m_Id: 2889061214707712
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889061311176704
    m_Localized: "\xC9coute, ce monde -- ton monde -- n'est pas ce qu'il para\xEEt
      \xEAtre. Tu as d\xFB t'en rendre compte maintenant."
    m_Metadata:
      m_Items: []
  - m_Id: 2889061411840000
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889061512503296
    m_Localized: "Ce miasme menace tout ce que tu connais. Tu dois d\xE9couvrir ce
      qui, ou qui, est derri\xE8re tout \xE7a."
    m_Metadata:
      m_Items: []
  - m_Id: 2889061613166592
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889061709635584
    m_Localized: "La r\xE9ponse se trouve dans tes propres souvenirs. Tu dois entreprendre
      un voyage \xE0 la recherche de tes 10 curiosit\xE9s de pouvoir pour d\xE9voiler
      la v\xE9rit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 2889061810298880
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889061915156480
    m_Localized: "Tu rencontreras de nombreux amis en chemin. Fais-leur confiance,
      compte sur eux. Tu as besoin de leur aide pour traverser \xE7a."
    m_Metadata:
      m_Items: []
  - m_Id: 2889062015819776
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889062116483072
    m_Localized: "Pars maintenant. Ta premi\xE8re curiosit\xE9, je la sens proche.
      Quelque part dans la banlieue voisine de Prim."
    m_Metadata:
      m_Items: []
  - m_Id: 2889062217146368
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889062317809664
    m_Localized: "Le m\xE9tro devrait t'y emmener. Attends, tu devrais le savoir,
      tu habites \xE0 Prim, N'EST-CE PAS ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889062418472960
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889062519136256
    m_Localized: "Oh l\xE0 l\xE0, je vois la lumi\xE8re. C'est vraiment la fin maintenant.
      Avant de partir, tu as bien \xE9cout\xE9, ou tu veux que je r\xE9p\xE8te ?"
    m_Metadata:
      m_Items: []
  - m_Id: 2889062623993856
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889062728851456
    m_Localized: Oui
    m_Metadata:
      m_Items: []
  - m_Id: 2889062833709056
    m_Localized: Frankie
    m_Metadata:
      m_Items: []
  - m_Id: 2889062934372352
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 2889063035035648
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889063139893248
    m_Localized: "Oh . . . vraiment ? Honn\xEAtement, je tiens \xE0 peine. Ok, j'imagine,
      voil\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2889063240556544
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889063345414144
    m_Localized: "D'accord. Eh bien, tu es un homme intelligent, capable et courageux,
      Frankie. N'oublie pas \xE7a."
    m_Metadata:
      m_Items: []
  - m_Id: 2889063446077440
    m_Localized: Phil Ramen
    m_Metadata:
      m_Items: []
  - m_Id: 2889063550935040
    m_Localized: "Je suis content de t'avoir rencontr\xE9. *squish* *slurp* *au revoir*"
    m_Metadata:
      m_Items: []
  - m_Id: 2889063655792640
    m_Localized: "D\xE9faut"
    m_Metadata:
      m_Items: []
  - m_Id: 2889063760650240
    m_Localized: "Texte par d\xE9faut \xE0 remplacer"
    m_Metadata:
