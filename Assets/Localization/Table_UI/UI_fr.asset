    m_Metadata:
      m_Items: []
  - m_Id: 7991831638827008
    m_Localized: "rat\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 7991869383368704
    m_Localized: CRITIQUE !
    m_Metadata:
      m_Items: []
  - m_Id: 7997758593032192
    m_Localized: Tu rencontres {0}.
    m_Metadata:
      m_Items: []
  - m_Id: 7997790486519808
    m_Localized: Tu rencontres {0} et sa bande.
    m_Metadata:
      m_Items: []
  - m_Id: 7997814947700736
    m_Localized: Que veux-tu faire ?
    m_Metadata:
      m_Items: []
  - m_Id: 7997834627375104
    m_Localized: "Ton groupe a gagn\xE9 {0} points d'exp\xE9rience."
    m_Metadata:
      m_Items: []
  - m_Id: 7997860300709888
    m_Localized: '{0} a atteint le niveau {1} !'
    m_Metadata:
      m_Items: []
  - m_Id: 7997880118796288
    m_Localized: "{0} a augment\xE9 de {1}."
    m_Metadata:
      m_Items: []
  - m_Id: 7997902138892288
    m_Localized: "Attends, {0} a trouv\xE9 quelque chose."
    m_Metadata:
      m_Items: []
  - m_Id: 7997925174009856
    m_Localized: "{0} a l\xE2ch\xE9 {1}, et tu l'as rang\xE9 dans ton sac \xE0 dos."
    m_Metadata:
      m_Items: []
  - m_Id: 7997945612853248
    m_Localized: "{0} a l\xE2ch\xE9 {1}, mais tu n'as plus de place. Tu veux jeter
      quelque chose ?"
    m_Metadata:
      m_Items: []
  - m_Id: 7997972309598208
    m_Localized: "T'es s\xFBr de vouloir abandonner {0} ?"
    m_Metadata:
      m_Items: []
  - m_Id: 7997998792433664
    m_Localized: Ouais
    m_Metadata:
      m_Items: []
  - m_Id: 7998019667484672
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 7998039489765376
    m_Localized: "T'as gagn\xE9 ! F\xE9licitations !"
    m_Metadata:
      m_Items: []
  - m_Id: 7998057474940928
    m_Localized: "On dirait que les choses ne se sont pas tout \xE0 fait pass\xE9es
      comme pr\xE9vu."
    m_Metadata:
      m_Items: []
  - m_Id: 7998077553074176
    m_Localized: Tu as pris la fuite.
    m_Metadata:
      m_Items: []
  - m_Id: 8003262832697344
    m_Localized: "{0} a r\xE9cup\xE9r\xE9 {1} PV."
    m_Metadata:
      m_Items: []
  - m_Id: 8003284227842048
    m_Localized: "{0} a re\xE7u {1} points de d\xE9g\xE2ts."
    m_Metadata:
      m_Items: []
  - m_Id: 8003305111281664
    m_Localized: "{0} a r\xE9cup\xE9r\xE9 {1} PA."
    m_Metadata:
      m_Items: []
  - m_Id: 8003344688734208
    m_Localized: '{0} a perdu {1} PA.'
    m_Metadata:
      m_Items: []
  - m_Id: 8003359918252032
    m_Localized: "{0} a \xE9t\xE9 mis hors combat."
    m_Metadata:
      m_Items: []
  - m_Id: 8003382676545536
    m_Localized: "{0} a retrouv\xE9 la volont\xE9 de se battre."
    m_Metadata:
      m_Items: []
  - m_Id: 8004517357412352
    m_Localized: Utiliser l'objet {0} sur quel ennemi ?
    m_Metadata:
      m_Items: []
  - m_Id: 8994215747903488
    m_Localized: Combattre
    m_Metadata:
      m_Items: []
  - m_Id: 8994259788095488
    m_Localized: Objet
    m_Metadata:
      m_Items: []
  - m_Id: 8994292197482496
    m_Localized: Stats
    m_Metadata:
      m_Items: []
  - m_Id: 8994330206265344
    m_Localized: Fuir
    m_Metadata:
      m_Items: []
  - m_Id: 8999697510293504
    m_Localized: "Aucune s\xE9lection"
    m_Metadata:
      m_Items: []
  - m_Id: 9002459291705344
    m_Localized: 'Inclination :'
    m_Metadata:
      m_Items: []
  - m_Id: 9002630037626880
    m_Localized: "Co\xFBt en PA :"
    m_Metadata:
      m_Items: []
  - m_Id: 9003945904037888
    m_Localized: "{0} a utilis\xE9 {1} sur {2}"
    m_Metadata:
      m_Items: []
  - m_Id: 9004005794504704
    m_Localized: Pas assez de PA.
    m_Metadata:
      m_Items: []
  - m_Id: 9004072169365504
    m_Localized: Aucune cible valide.
    m_Metadata:
      m_Items: []
  - m_Id: 9041979810766848
    m_Localized: "Tu as actuellement {0} en fonds. Combien veux-tu d\xE9poser ?"
    m_Metadata:
      m_Items: []
  - m_Id: 9042015114223616
    m_Localized: Tu as actuellement {0} en banque. Combien veux-tu retirer ?
    m_Metadata:
      m_Items: []
  - m_Id: 9043485888864256
    m_Localized: Ok
    m_Metadata:
      m_Items: []
  - m_Id: 9043523323027456
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 9045403184914432
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 9054858278592512
    m_Localized: "Il n'y a rien dans le sac \xE0 dos \xE0 \xE9quiper."
    m_Metadata:
      m_Items: []
  - m_Id: 9054899747676160
    m_Localized: "On dirait qu'on y va \xE0 poil"
    m_Metadata:
      m_Items: []
  - m_Id: 9054925978853376
    m_Localized: Que veux-tu faire ?
    m_Metadata:
      m_Items: []
