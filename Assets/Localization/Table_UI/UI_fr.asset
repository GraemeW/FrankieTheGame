  - m_Id: 9090354954362880
    m_Localized: "T'es s\xFBr de vouloir abandonner {0} ?"
    m_Metadata:
      m_Items: []
  - m_Id: 9096149108514816
    m_Localized: "\xC9quiper"
    m_Metadata:
      m_Items: []
  - m_Id: 9096179089399808
    m_Localized: "Cet objet ne peut pas \xEAtre \xE9quip\xE9 ici."
    m_Metadata:
      m_Items: []
  - m_Id: 9097773231104000
    m_Localized: "T'es s\xFBr de vouloir ramasser {0} et abandonner {1} ?"
